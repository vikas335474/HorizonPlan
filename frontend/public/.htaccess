# HorizonPlan — React Router SPA rewrite + security headers.
#
# Without the rewrite, opening or refreshing /goals, /settings, etc. returns a
# 404 (or 403 on hosts with directory indexes disabled) because the server looks
# for a literal file at that path. These rules serve real files/assets as-is,
# leave /api to PHP, and send everything else to index.html for React Router.
#
# NOTE: intentionally no `Options -Indexes` line — some shared hosts (incl. some
# Hostinger/LiteSpeed configs) reject `Options` in .htaccess and return 403.
# Directory listing isn't a real exposure here anyway: every servable dir has an
# index.html and the SPA rewrite already covers non-file paths.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Serve index.html itself directly (avoids a rewrite loop)
    RewriteRule ^index\.html$ - [L]

    # Real files and directories (JS/CSS in /assets, favicon, etc.) served as-is
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # /api/* is handled by PHP, never rewritten to the SPA
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule . /index.html [L]
</IfModule>

# Security headers — belt-and-suspenders alongside sameSite=Strict cookie flags.
# Guarded by IfModule so a host without mod_headers simply skips them (no 500).
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
